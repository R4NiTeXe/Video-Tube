# ── Server ──
PORT=8000
# ⚠️ REQUIRED: Set to "production" in production (enables security features, error sanitization, HSTS, etc.)
NODE_ENV=development
# Number of reverse proxy hops between client and this server.
#   1 (default): behind nginx only (one proxy)
#   2: behind CDN (e.g. Cloudflare) + nginx
#   true: trust all proxies (only if external X-Forwarded-For headers are stripped upstream)
# Required for correct rate limiting, IP logging, and session IP tracking behind proxies.
PROXY_TRUST_COUNT=1

# ── MongoDB ──
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net
# DNS_SERVERS=8.8.8.8,8.8.4.4  # optional, defaults to system DNS

# ── CORS ──
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── JWT ──
ACCESS_TOKEN_SECRET=<random-64-char-hex>
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=<random-64-char-hex>
REFRESH_TOKEN_EXPIRY=10d

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Email (Brevo SMTP primary, Resend fallback) ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>
MAIL_FROM=<your-email>
RESEND_API_KEY=<your-resend-key>
RESEND_FROM=VideoTube <onboarding@resend.dev>

# ── File Upload Limits (MB) ──
MAX_VIDEO_SIZE_MB=20
MAX_THUMBNAIL_SIZE_MB=2
MAX_IMAGE_SIZE_MB=5

# ── OAuth ──
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>
FACEBOOK_APP_ID=<your-facebook-app-id>
FACEBOOK_APP_SECRET=<your-facebook-app-secret>
DISCORD_CLIENT_ID=<your-discord-client-id>
DISCORD_CLIENT_SECRET=<your-discord-client-secret>

# ── WhatsApp Business API ──
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>
WHATSAPP_ACCESS_TOKEN=<your-whatsapp-access-token>
WHATSAPP_MODE=text
WHATSAPP_TEMPLATE_NAME=otp_verification
WHATSAPP_LANGUAGE_CODE=en

# ── Redis (optional — falls back to in-memory) ──
REDIS_URL=redis://localhost:6379

# ── Sentry (optional) ──
SENTRY_DSN=<your-sentry-dsn>
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Logging ──
LOG_LEVEL=info

# ── Content Moderation (optional — comma-separated banned words) ──
CONTENT_BANNED_WORDS=

# ── Webhook Secret (optional — secures Cloudinary webhook) ──
WEBHOOK_SECRET=
