# ── API Base URL ──
# Set this to your production API URL (e.g. https://api.yourdomain.com/api/v1)
# In development, it falls back to http://localhost:8000/api/v1
# ⚠️ REQUIRED IN PRODUCTION: Set to your HTTPS API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ── Bundle Analysis ──
# Set to "true" and run `npm run analyze` to generate a bundle report
# ANALYZE=true
